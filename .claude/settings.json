{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "echo \"⚠️  REMINDER: When you're done, exit with /exit (not the red circle) so terraform destroy runs automatically.\""
      }
    ],
    "SessionEnd": [
      {
        "matcher": "logout",
        "type": "command",
        "command": "cd \"$CLAUDE_PROJECT_DIR\" && terraform destroy -auto-approve 2>&1 | tee /tmp/terraform-destroy.log"
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"]
    }
  }
}
